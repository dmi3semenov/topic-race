# topic-race — .env template
#
# Credentials читаются из shell env (~/.zshrc → ~/.claude/secrets/*.env).
# В .env нужны только project-specific переменные.
#
# Если запуск без shell (CI / Docker / launchd) — раскомментируй и
# заполни credentials из ~/.claude/secrets/telegram.env.

# Credentials (обычно из shell env, не нужны в .env):
# TG_API_ID=
# TG_API_HASH=
# TG_PHONE=+7...

# Project-specific (оставить в .env):
TG_GROUP_NAME=Материалы
TG_SESSION_NAME=topic_race
